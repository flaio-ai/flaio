{
  "name": "agent-manager",
  "version": "0.1.0",
  "description": "Terminal UI for managing multiple AI CLI agents with tabbed sessions",
  "type": "module",
  "bin": {
    "agent-manager": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest",
    "install-hooks": "tsx src/hooks/install.ts install",
    "uninstall-hooks": "tsx src/hooks/install.ts uninstall"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@xterm/headless": "^5.5.0",
    "commander": "^13.1.0",
    "ink": "^5.2.1",
    "node-pty": "^1.2.0-beta.11",
    "react": "^18.3.1",
    "zod": "^3.24.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.0"
  }
}
