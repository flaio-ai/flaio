{
  "name": "flaio-cli",
  "version": "1.0.10",
  "description": "Terminal UI for managing multiple AI CLI agents with tabbed sessions",
  "license": "MIT",
  "type": "module",
  "author": "George Livas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaio-ai/flaio.git"
  },
  "homepage": "https://github.com/flaio-ai/flaio",
  "bugs": {
    "url": "https://github.com/flaio-ai/flaio/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "claude",
    "gemini",
    "terminal",
    "tui",
    "ink",
    "node-pty",
    "flaio"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "flaio": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "dev:local": "RELAY_URL=ws://localhost:8080 AUTH_URL=http://localhost:5173/auth/cli tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest --passWithNoTests",
    "prepublishOnly": "npm run build",
    "install-hooks": "tsx src/hooks/install.ts install",
    "uninstall-hooks": "tsx src/hooks/install.ts uninstall",
    "changeset": "changeset",
    "dev:debug-gc": "node --expose-gc --trace-gc dist/cli.js",
    "dev:debug-heap": "node --max-old-space-size=512 --heapsnapshot-near-heap-limit=3 dist/cli.js"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@sentry/node": "^10.42.0",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "@xterm/headless": "^5.5.0",
    "commander": "^13.1.0",
    "ink": "^6.8.0",
    "node-pty": "^1.2.0-beta.11",
    "posthog-node": "^5.28.0",
    "react": "^19.2.4",
    "zod": "^3.24.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.0"
  }
}
