---
import DocsLayout from '../../layouts/DocsLayout.astro';
import KeyboardShortcutTable from '../../components/docs/KeyboardShortcutTable.astro';
import Callout from '../../components/docs/Callout.astro';

const headings = [
  { depth: 2, slug: 'navigation', text: 'Navigation' },
  { depth: 2, slug: 'scrolling', text: 'Scrolling' },
  { depth: 2, slug: 'panels--modals', text: 'Panels & Modals' },
  { depth: 2, slug: 'application', text: 'Application' },
];
---
<DocsLayout title="Keyboard Shortcuts" headings={headings}>
  <Callout type="tip">
    <p>
      Press <code>Ctrl+G</code> inside the app to see this reference at any time.
    </p>
  </Callout>

  <KeyboardShortcutTable />
</DocsLayout>
