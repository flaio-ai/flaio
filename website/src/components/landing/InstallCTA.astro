---
---
<section class="py-24 px-6" id="install">
  <div class="max-w-2xl mx-auto text-center fade-in">
    <h2 class="text-3xl font-bold text-text-primary mb-8">Get started in seconds</h2>
    <div class="terminal-chrome inline-block w-full max-w-lg">
      <div class="terminal-titlebar">
        <span class="terminal-dot terminal-dot-red"></span>
        <span class="terminal-dot terminal-dot-yellow"></span>
        <span class="terminal-dot terminal-dot-green"></span>
      </div>
      <div class="p-6 font-mono text-sm text-left">
        <span class="text-text-secondary">$</span>
        <span class="text-status-running ml-2">npm install -g agent-manager</span>
      </div>
    </div>
    <p class="mt-8 text-text-secondary">
      Then run <code class="bg-card px-2 py-0.5 rounded text-brand-accent">agent-manager</code> to launch.
    </p>
    <a
      href="/docs"
      class="inline-block mt-4 text-brand-accent hover:underline"
    >
      Read the docs &rarr;
    </a>
  </div>
</section>
