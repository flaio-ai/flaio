---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/shared/Header.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import TableOfContents from '../components/docs/TableOfContents.astro';
import { flatNavItems } from '../data/navigation';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, headings = [] } = Astro.props;

const flatItems = flatNavItems();
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/docs';
const currentIdx = flatItems.findIndex((item) => item.href === currentPath);
const prev = currentIdx > 0 ? flatItems[currentIdx - 1] : null;
const next = currentIdx < flatItems.length - 1 ? flatItems[currentIdx + 1] : null;
---
<BaseLayout title={`${title} — Flaio Docs`} description={description}>
  <Header />
  <div class="max-w-[90rem] mx-auto flex">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-64 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto border-r border-border-default p-6">
      <DocsSidebar currentPath={currentPath} />
    </aside>

    <!-- Mobile sidebar toggle -->
    <input type="checkbox" id="sidebar-toggle" class="hidden peer" />
    <label
      for="sidebar-toggle"
      class="lg:hidden fixed top-20 left-4 z-50 bg-card border border-border-default rounded-lg p-2 cursor-pointer hover:bg-card-hover"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 5h14M3 10h14M3 15h14" />
      </svg>
    </label>
    <aside class="lg:hidden fixed inset-0 z-40 bg-page/95 backdrop-blur-sm p-6 pt-24 overflow-y-auto hidden peer-checked:block">
      <label for="sidebar-toggle" class="absolute top-5 right-5 cursor-pointer text-text-secondary hover:text-text-primary">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </label>
      <DocsSidebar currentPath={currentPath} />
    </aside>

    <!-- Content -->
    <main class="flex-1 min-w-0 px-6 py-10 lg:px-12">
      <article class="max-w-3xl">
        <h1 class="text-3xl font-bold mb-2 text-text-primary">{title}</h1>
        <div class="h-1 w-12 bg-brand-accent/40 rounded-full mb-8"></div>
        <div class="prose">
          <slot />
        </div>

        <!-- Prev/Next navigation -->
        <nav class="mt-16 pt-8 border-t border-border-default flex justify-between gap-4">
          {prev ? (
            <a href={prev.href} class="group flex-1 flex flex-col rounded-lg border border-border-default p-4 hover:border-brand-accent/40 hover:bg-card/30 transition-all">
              <span class="text-xs text-text-secondary mb-1.5 flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 3L5 8l5 5" /></svg>
                Previous
              </span>
              <span class="text-brand-accent font-medium">{prev.title}</span>
            </a>
          ) : <div class="flex-1" />}
          {next ? (
            <a href={next.href} class="group flex-1 flex flex-col items-end rounded-lg border border-border-default p-4 hover:border-brand-accent/40 hover:bg-card/30 transition-all">
              <span class="text-xs text-text-secondary mb-1.5 flex items-center gap-1">
                Next
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3l5 5-5 5" /></svg>
              </span>
              <span class="text-brand-accent font-medium">{next.title}</span>
            </a>
          ) : <div class="flex-1" />}
        </nav>
      </article>
    </main>

    <!-- Table of Contents -->
    {headings.length > 0 && (
      <aside class="hidden xl:block w-56 shrink-0 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto p-6">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .prose {
    @apply text-text-primary leading-relaxed;
  }
  .prose h2 {
    @apply text-xl font-semibold mt-12 mb-4 pt-6 border-t border-border-default/50 text-text-primary;
  }
  .prose h2:first-child {
    @apply mt-0 pt-0 border-t-0;
  }
  .prose h3 {
    @apply text-lg font-medium mt-8 mb-3 text-text-primary;
  }
  .prose p {
    @apply mb-4 text-text-secondary;
  }
  .prose ul, .prose ol {
    @apply mb-4 pl-6 text-text-secondary;
  }
  .prose ul {
    @apply list-disc;
  }
  .prose ol {
    @apply list-decimal;
  }
  .prose li {
    @apply mb-2 leading-relaxed;
  }
  .prose a {
    @apply text-brand-accent;
  }
  .prose strong {
    @apply text-text-primary font-semibold;
  }
  .prose table {
    @apply w-full mb-6;
  }
  .prose th {
    @apply text-left px-4 py-2.5 text-text-primary font-medium text-sm;
  }
  .prose td {
    @apply px-4 py-2.5 text-text-secondary text-sm;
  }
  .prose pre {
    @apply mb-6;
  }
  .prose blockquote {
    @apply border-l-4 border-brand-accent/60 bg-brand-accent/5 rounded-r-lg pl-4 pr-4 py-3 my-6 text-text-secondary not-italic;
  }
  .prose > .callout + h2 {
    @apply mt-8 pt-0 border-t-0;
  }
</style>
