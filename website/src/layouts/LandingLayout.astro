---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/shared/Header.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <slot />
  </main>
</BaseLayout>
